                {
                  "id": "phase-g",
                  "type": "frame",
                  "layout": "vertical",
                  "width": 280,
                  "height": "fit_content",
                  "gap": 12,
                  "padding": 20,
                  "fill": "#1A1A1AFF",
                  "cornerRadius": 12,
                  "children": [
                    {
                      "id": "phase-g-letter",
                      "type": "frame",
                      "layout": "horizontal",
                      "width": 32,
                      "height": 32,
                      "fill": "#A855F7FF",
                      "cornerRadius": 6,
                      "alignItems": "center",
                      "children": [
                        { "id": "phase-g-char", "type": "text", "textGrowth": "auto", "content": "G", "fontFamily": "Playfair Display", "fontSize": 16, "fontWeight": "700", "fill": "#FFFFFFFF" }
                      ]
