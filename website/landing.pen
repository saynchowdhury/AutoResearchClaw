                      ]
                    },
                    { "id": "phase-f-title", "type": "text", "textGrowth": "auto", "content": "Analysis & Decision", "fontFamily": "Geist", "fontSize": 15, "fontWeight": "600", "fill": "#FFFFFFFF" },
                    { "id": "phase-f-desc", "type": "text", "textGrowth": "fixed-width", "width": "fill_container", "content": "Result analysis with pivot/refine/proceed decisions.", "fontFamily": "Geist", "fontSize": 13, "fill": "#71717AFF", "lineHeight": 1.5 },
                    {
                      "id": "phase-f-dots",
                      "type": "frame",
